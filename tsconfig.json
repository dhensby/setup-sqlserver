{
  "extends": "@tsconfig/node24",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "outDir": "./lib",
    "rootDir": "./src",
    "sourceMap": true,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "types": ["node", "mocha"]
  },
  "exclude": ["test", "lib", "node_modules", "misc"]
}

